    <worksheet name='Career Changer - Scatter'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#ffffff'>Avg. Median Salary &amp; Avg.Automation Risk Sweet Spot</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#ffffff' fontname='Benton Sans Book'>On the scatter plot: orange dots represent roles with above-average salary and below-average automation risk within your current selection — your sweet spot.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
