          <alias key='&quot;[federated.0zkye0v0ev2j971b2q8he0505eqy].[usr:Calculation_4991625073799181:qk:1]&quot;' value='Net Job Change' />
          <alias key='&quot;[federated.0zkye0v0ev2j971b2q8he0505eqy].[usr:Calculation_4991625073963022:qk:1]&quot;' value='Remote Work' />
