            <column caption='Actual Job Status' datatype='string' name='[Calculation_4991624670445570]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Projected Openings (2030)] &gt; [Job Openings (2024)]&#10;THEN &quot;Increasing&quot;&#10;ELSE &quot;Decreasing&quot;&#10;END' />
            </column>
            <column caption='Sweet Spot (Jobs)' datatype='string' name='[Calculation_4991624679247875]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF AVG([Median Salary (USD)]) &gt;= WINDOW_AVG(AVG([Median Salary (USD)])) &#10;AND AVG([Automation Risk (%)]) &lt;= WINDOW_AVG(AVG([Automation Risk (%)]))&#10;THEN &quot;Sweet Spot&quot;&#10;ELSE &quot;Other&quot;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='integer' default-format='n#,##0.0;-#,##0.0' name='[Experience Required (Years)]' role='measure' type='quantitative' />
