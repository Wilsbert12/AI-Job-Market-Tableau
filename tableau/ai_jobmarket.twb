      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0zkye0v0ev2j971b2q8he0505eqy].[avg:Calculation_4991625074446352:qk]&quot;' value='AI Impact Level' />
