        </aliases>
      </column>
      <column datatype='real' default-format='n#,##0&quot;%&quot;;-#,##0&quot;%&quot;' name='[Automation Risk (%)]' role='measure' type='quantitative' />
      <column caption='Net Job Change (2024-2030)' datatype='integer' name='[Calculation_4991624308985856]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Projected Openings (2030)])-SUM([Job Openings (2024)])' />
      </column>
      <column caption='Contradiction (Job Status vs. Offerings)' datatype='string' name='[Calculation_4991624669507585]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Job Status] = &quot;Increasing&quot; AND &#10;[Projected Openings (2030)] &lt; [Job Openings (2024)]&#10;THEN &quot;Contradiction&quot;&#10;ELSE &quot;Consistent&quot;&#10;END' />
      </column>
      <column caption='Actual Job Status' datatype='string' name='[Calculation_4991624670445570]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Projected Openings (2030)] &gt; [Job Openings (2024)]&#10;THEN &quot;Increasing&quot;&#10;ELSE &quot;Decreasing&quot;&#10;END' />
      </column>
      <column caption='Sweet Spot (Jobs)' datatype='string' name='[Calculation_4991624679247875]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([Median Salary (USD)]) &gt;= WINDOW_AVG(AVG([Median Salary (USD)])) &#10;AND AVG([Automation Risk (%)]) &lt;= WINDOW_AVG(AVG([Automation Risk (%)]))&#10;THEN &quot;Sweet Spot&quot;&#10;ELSE &quot;Other&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Salary Rank' datatype='string' name='[Calculation_4991624748986374]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF RANK(AVG([Median Salary (USD)])) &lt;= [Parameters].[Parameter 1]&#10;THEN &quot;Show&quot;&#10;ELSE &quot;Hide&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='AI Impact Level (Numeric)' datatype='real' name='[Calculation_4991625069936650]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [AI Impact Level] = &quot;Low&quot; THEN 0&#10;ELSEIF [AI Impact Level] = &quot;Medium&quot; THEN 0.5&#10;ELSE 1&#10;END' />
      </column>
      <column caption='Norm - Automation Risk' datatype='real' name='[Calculation_4991625072328715]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - (AVG([Automation Risk (%)]) - WINDOW_MIN(AVG([Automation Risk (%)]))) &#10;/ &#10;(WINDOW_MAX(AVG([Automation Risk (%)])) - WINDOW_MIN(AVG([Automation Risk (%)])))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Norm - Median Salary' datatype='real' name='[Calculation_4991625073606668]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Median Salary (USD)]) - WINDOW_MIN(AVG([Median Salary (USD)]))) &#10;/ &#10;(WINDOW_MAX(AVG([Median Salary (USD)])) - WINDOW_MIN(AVG([Median Salary (USD)])))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Norm - Net Job Change' datatype='real' name='[Calculation_4991625073799181]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Projected Openings (2030)]) - SUM([Job Openings (2024)]) - WINDOW_MIN(SUM([Projected Openings (2030)]) - SUM([Job Openings (2024)]))) &#10;/ &#10;(WINDOW_MAX(SUM([Projected Openings (2030)]) - SUM([Job Openings (2024)])) - WINDOW_MIN(SUM([Projected Openings (2030)]) - SUM([Job Openings (2024)])))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Norm - Remote Work Ratio' datatype='real' name='[Calculation_4991625073963022]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Remote Work Ratio (%)]) - WINDOW_MIN(AVG([Remote Work Ratio (%)]))) &#10;/ &#10;(WINDOW_MAX(AVG([Remote Work Ratio (%)])) - WINDOW_MIN(AVG([Remote Work Ratio (%)])))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Norm - Gender Diversity' datatype='real' name='[Calculation_4991625074221071]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Gender Diversity (%)]) - WINDOW_MIN(AVG([Gender Diversity (%)]))) &#10;/ &#10;(WINDOW_MAX(AVG([Gender Diversity (%)])) - WINDOW_MIN(AVG([Gender Diversity (%)])))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Norm - AI Impact Level' datatype='real' name='[Calculation_4991625074446352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - [Calculation_4991625069936650]' />
      </column>
      <column caption='Total Structural Change' datatype='integer' name='[Calculation_4991625303642130]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(ABS([Projected Openings (2030)] - [Job Openings (2024)]))' />
      </column>
      <column caption='Net Job Change %' datatype='real' name='[Calculation_4991625309773843]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Projected Openings (2030)]) - SUM([Job Openings (2024)])) &#10;/ SUM([Job Openings (2024)]) * 100' />
      </column>
      <column caption='Structural Change %' datatype='real' name='[Calculation_4991625309982740]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(ABS([Projected Openings (2030)] - [Job Openings (2024)])) &#10;/ SUM([Job Openings (2024)]) * 100' />
      </column>
      <column caption='Box' datatype='string' name='[Calculation_4991626014834709]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;&quot;' />
      </column>
